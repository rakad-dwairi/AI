# Copy this file to .env and fill only the tools you want to run.

# OpenAI transcription / text analysis
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Deepgram transcription
DEEPGRAM_API_KEY=

# Hume expression analysis
HUME_API_KEY=

# AWS Rekognition
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=3Wc/

# Azure Video Indexer
AZURE_VIDEO_INDEXER_ACCOUNT_ID=
AZURE_VIDEO_INDEXER_LOCATION=trial
AZURE_VIDEO_INDEXER_ACCESS_TOKEN=